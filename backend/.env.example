# ╔══════════════════════════════════════════════════════════╗
# ║  Coca-Cola Landing Page — Variables de Entorno          ║
# ║  Copia este archivo como .env y rellena los valores     ║
# ║  cp .env.example .env                                   ║
# ╚══════════════════════════════════════════════════════════╝

# ── Base de Datos (Prisma) ──────────────────────────────────
# SQLite (desarrollo local):
DATABASE_URL="file:./dev.db"
# PostgreSQL (producción recomendada):
# DATABASE_URL="postgresql://user:password@localhost:5432/cocacola?schema=public"

# ── Google OAuth 2.0 ────────────────────────────────────────
# Obtén tus credenciales en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="tu-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-tu-google-client-secret"

# ── Correo (Nodemailer con Gmail) ───────────────────────────
# Genera una contraseña de aplicación en: https://myaccount.google.com/apppasswords
EMAIL_USER="tu-email@gmail.com"
EMAIL_PASS="xxxx-xxxx-xxxx-xxxx"

# ── Sesiones (Express Session) ──────────────────────────────
# Genera un secreto seguro: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET="tu-session-secret-de-al-menos-64-caracteres-aqui"

# ── Redis ───────────────────────────────────────────────────
REDIS_URL="redis://127.0.0.1:6379"

# ── Servidor ────────────────────────────────────────────────
# DESARROLLO:
PORT=4000
FRONTEND_URL="http://localhost:5173"
VITE_API_URL="http://localhost:4000/api"

# PRODUCCIÓN (descomenta y ajusta):
# PORT=4001
# FRONTEND_URL="https://tu-dominio.com"
# VITE_API_URL="https://tu-dominio.com/api"
